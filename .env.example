# ════════════════════════════════
# DJANGO
# ════════════════════════════════
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True
DJANGO_SETTINGS_MODULE=core.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Step 1: keep True to run on SQLite with zero infra.
# Step 2: set to False to use PostgreSQL below.
USE_SQLITE=True

# ════════════════════════════════
# DATABASE — PostgreSQL (Step 2)
# ════════════════════════════════
DB_NAME=law_enforcement_db
DB_USER=le_user
DB_PASSWORD=your_strong_password
DB_HOST=localhost
DB_PORT=5432

# ════════════════════════════════
# REDIS (Phase 5)
# ════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ════════════════════════════════
# AWS (Phase 3)
# ════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_BUCKET_REGION=us-east-1

# ════════════════════════════════
# AI MODEL (Phase 3)
# ════════════════════════════════
USE_LOCAL_MODEL=True
LOCAL_MODEL_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.2
BEDROCK_MODEL_ID=
BEDROCK_REGION=us-east-1

# ════════════════════════════════
# EMAIL — SMTP (Phase 2: verification + password reset)
# ════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=Your App <your-email@gmail.com>

# ════════════════════════════════
# STRIPE (Phase 4)
# The STRIPE_PRICE_* vars below are a one-time bootstrap only, read by
# `manage.py seed_plans` to populate Plan.stripe_price_id_monthly/yearly the
# first time a plan is created. After that, the database is the live source
# of truth — edit prices in the admin panel, no redeploy needed.
# ════════════════════════════════
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
